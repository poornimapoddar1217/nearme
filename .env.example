## Database (SQLite default)
# For local dev this creates prisma/dev.db
DATABASE_URL="file:./dev.db"

## Google Maps / Places
# GOOGLE_MAPS_API_KEY is only needed as a fallback if Apify Maps is not configured.
GOOGLE_MAPS_API_KEY=""
# Still required for the browser map tile rendering (not the search).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""

## Apify — scraping (replaces Google Places search when set)
APIFY_TOKEN=""
# Google Maps scraper: recommended actor is compass/google-maps-scraper
APIFY_MAPS_ACTOR_ID="compass/google-maps-scraper"
# Review / social page scrapers (used by the business report)
APIFY_REVIEW_ACTOR_ID="compass/crawler-google-places"
# Platform-specific social scrapers (auto-selected by URL)
APIFY_INSTAGRAM_ACTOR_ID="apify/instagram-scraper"
APIFY_LINKEDIN_ACTOR_ID="dev_fusion/Linkedin-Profile-Scraper"
# Generic fallback for other social/website URLs
APIFY_SOCIAL_ACTOR_ID=""

## AI (competitor summary)
# Use one of the two below. OpenRouter keys (sk-or-v1...) are auto-detected.
OPENROUTER_API_KEY=""
OPENAI_API_KEY=""

## Logging
LOG_LEVEL="info"

